# Copy this file to .env and fill in real values.

ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opening_doctor

# --- Qdrant ---
# "local"  -> embedded, file-backed Qdrant (no server needed, good for dev / no-Docker setups)
# "server" -> talk to a real Qdrant instance at QDRANT_URL (used by docker-compose)
QDRANT_MODE=local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=opening_knowledge

# --- Embeddings / Reranker (free, CPU, run locally via fastembed/ONNX) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# --- LLM provider: "ollama" (local, keyless, default), "groq" (free+fast, needs a key), or "openai" (GPT-5) ---
LLM_PROVIDER=ollama

# Default: local Ollama server, no API key needed. Run `ollama pull llama3.2:1b` first
# (or point OLLAMA_MODEL at any other model you've pulled).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:1b

# Optional faster/higher-quality alternative: a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
